# =====================================================================
# FitManager — production environment (root, used by docker-compose)
# Copy to ".env" and replace every placeholder before deploying.
#   cp .env.production.example .env
# =====================================================================

NODE_ENV=production
PORT=5000

# ---- Database --------------------------------------------------------
# Bundled Postgres (docker-compose `db` service): these three feed it and
# the DATABASE_URL below points at the `db` host on the compose network.
POSTGRES_USER=fitmanager
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=fitmanager

DATABASE_URL=postgresql://fitmanager:CHANGE_ME_strong_db_password@db:5432/fitmanager

# Using managed Postgres (Neon / RDS) instead? Comment out the `db` service in
# docker-compose.yml and use its connection string here, for example:
# DATABASE_URL=postgresql://user:pass@ep-xxxx.ap-south-1.aws.neon.tech/fitmanager?sslmode=require

# ---- JWT secrets -----------------------------------------------------
# Generate each with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_long_random_64_char_minimum_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_long_random_64_char_minimum_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- CORS ------------------------------------------------------------
# Public origin(s) of the frontend. With the bundled nginx proxy the browser
# calls are same-origin, but set this to your real domain anyway.
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ---- First platform admin (created once by `npm run seed`) -----------
SEED_ADMIN_NAME=Platform Admin
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ---- Platform contact (gym owners pay you here, then you activate them) ----
# WhatsApp number in international format, no '+'. Optional UPI QR image URL.
PLATFORM_WHATSAPP=919876543210
PLATFORM_UPI_QR_URL=
