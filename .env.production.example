# =====================================================================
# FitManager — production environment values (API / Render)
# These are the variables the API needs in production. Set them in your
# host's dashboard (Render → Environment). For local prod testing you can
# copy them into server/.env. Do NOT commit real secrets.
# =====================================================================

NODE_ENV=production
PORT=5000

# ---- Database (Neon — AWS ap-south-1 / Mumbai recommended) ----
# Neon connection string (already includes ?sslmode=require).
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-south-1.aws.neon.tech/fitmanager?sslmode=require

# ---- JWT secrets ----
# Generate each with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_long_random_64_char_minimum_access_secret
JWT_REFRESH_SECRET=CHANGE_ME_long_random_64_char_minimum_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- CORS ----
# Your Vercel frontend origin(s), comma-separated. No trailing slash.
CORS_ORIGINS=https://your-app.vercel.app

# ---- First platform admin (created once by `npm run seed`) ----
SEED_ADMIN_NAME=Platform Admin
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ---- Platform contact (gym owners pay you here, then you activate them) ----
# WhatsApp number in international format, no '+'. Optional UPI QR image URL.
PLATFORM_WHATSAPP=919876543210
PLATFORM_UPI_QR_URL=

# ---- Frontend build var (set on VERCEL, not here) ----
# The web app reads this at build time; it's not an API variable:
#   VITE_API_URL=https://gym-management-jm0b.onrender.com/api/v1
