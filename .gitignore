# Dependencies (re-installed with `npm install`)
node_modules/
**/node_modules/

# Secrets — NEVER commit these
.env
.env.*
!.env.example
!.env.production.example
# The frontend API URL is public (it ships in the JS bundle), so the client's
# production build config IS committed so Vercel always builds with it.
!client/.env.production

# Build output (re-generated with `npm run build`)
dist/
**/dist/

# Logs & OS junk
*.log
npm-debug.log*
.DS_Store
Thumbs.db
